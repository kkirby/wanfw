{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wanfw.dev/schemas/envelope.schema.json",
  "title": "Document envelope",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "type": "string", "enum": ["Framework", "Service", "PluginConfig"] },
    "metadata": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "displayName": { "type": "string" }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    "spec": { "type": "object" }
  },
  "required": ["schemaVersion", "kind", "metadata", "spec"],
  "additionalProperties": false
}
