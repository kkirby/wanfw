{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wanfw.dev/schemas/framework.schema.json",
  "title": "Framework document spec (§5.3)",
  "type": "object",
  "properties": {
    "domain": { "type": "string", "minLength": 1 },
    "deploymentMode": { "type": "string", "enum": ["subdomain", "port"] },
    "acmeEmail": { "type": "string", "format": "email" },
    "roles": {
      "type": "object",
      "properties": {
        "networkProvider": { "type": "string" },
        "proxyEngine": { "type": "string" },
        "certIssuer": { "type": "string" },
        "dnsProvider": { "type": "string" }
      },
      "required": ["networkProvider", "proxyEngine"],
      "additionalProperties": false
    },
    "strictApprovals": { "type": "string", "enum": ["powerful", "all"], "default": "powerful" },
    "network": {
      "type": "object",
      "properties": {
        "lanInterface": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*(\\.[0-9]{1,4})?$",
          "description": "Host network interface name, e.g. 'eth0'. A VLAN-segmented LAN needs the tagged sub-interface instead, e.g. 'eth0.50' -- the bare parent NIC name will not see that VLAN's traffic."
        },
        "macvlan": {
          "type": "object",
          "properties": {
            "parent": {
              "type": "string",
              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*(\\.[0-9]{1,4})?$",
              "description": "Host interface macvlan attaches to, e.g. 'eth0' -- or 'eth0.50' if this LAN is VLAN-segmented (see lanInterface)."
            },
            "reservedCidr": {
              "type": "string",
              "pattern": "^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)){3}/(3[0-2]|[12]?[0-9])$",
              "description": "A CIDR slice reserved outside your DHCP pool, e.g. '192.168.1.240/29'."
            },
            "gateway": {
              "type": "string",
              "pattern": "^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)(\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)){3}$",
              "description": "Your LAN's gateway IP, e.g. '192.168.1.1'."
            }
          },
          "required": ["parent", "reservedCidr", "gateway"],
          "additionalProperties": false
        }
      },
      "required": ["lanInterface"],
      "additionalProperties": false
    }
  },
  "required": ["domain", "deploymentMode", "acmeEmail", "roles"],
  "additionalProperties": false
}
